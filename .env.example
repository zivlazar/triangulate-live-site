# Instagram owned-media sync.
# Use a token generated through the official Meta/Instagram app flow.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
# Defaults to graph.instagram.com/v22.0. For Instagram Graph API with Facebook Login,
# use a graph.facebook.com version URL instead, for example:
# INSTAGRAM_GRAPH_BASE=https://graph.facebook.com/v24.0
INSTAGRAM_GRAPH_BASE=https://graph.instagram.com/v22.0

# TikTok owned-video sync.
# Requires a TikTok user access token with the video.list scope.
TIKTOK_ACCESS_TOKEN=

# Optional local controls.
SOCIAL_POST_LIMIT=8
